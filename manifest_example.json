{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extension_name__",
  "description": "__MSG_extension_description__",
  "version": "0.1.3",
  "minimum_chrome_version": "127",
  "icons": {
    "16": "assets/Frame 9.png",
    "32": "assets/Frame 10.png",
    "48": "assets/Frame 11.png",
    "64": "assets/Frame 12.png",
    "96": "assets/Frame 13.png",
    "128": "assets/Frame 14.png"
  },
  "permissions": [
    "downloads",
    "downloads.open",
    "tabs",
    "scripting",
    "downloads.ui",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "__MSG_action_default_title__",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "page-download-toast.js"
      ]
    }
  ],
  "feedback_config": {
    "endpoint": "",
    "token": "",
    "form": "",
    "review": ""
  }
}
